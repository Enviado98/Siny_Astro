---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Schedule a Free Consultation – Guzman Tax Accounting" description="Schedule your free consultation with tax and accounting experts in Las Vegas. No commitment, bilingual service." lang="en" langHref="/consulta-gratuita">
<section class="page-hero"><div class="container"><div class="breadcrumb"><a href="/en/">Home</a> <span>›</span> <span>Free Consultation</span></div><h1>Schedule a Consultation</h1><p>No commitment. No hidden fees. We explain everything in your language.</p></div></section>
<section class="section"><div class="container"><div class="contact-grid">
  <div class="contact-info"><p class="eyebrow">How Does It Work?</p><h2>Your First Consultation, Free</h2><p>Call us, WhatsApp or complete the form. One of our experts will contact you to understand your situation and guide you at no cost.</p>
    <div class="mission-points"><div class="mission-point"><div class="mission-point-icon">1</div><div class="mission-point-text"><h4>Contact Us</h4><p>Call, WhatsApp or fill out the form.</p></div></div><div class="mission-point"><div class="mission-point-icon">2</div><div class="mission-point-text"><h4>We Evaluate Your Case</h4><p>We explain what service you need and the cost.</p></div></div><div class="mission-point"><div class="mission-point-icon">3</div><div class="mission-point-text"><h4>You Decide</h4><p>No pressure. You decide if you want to continue.</p></div></div></div>
    <div style="margin-top:32px;display:flex;flex-direction:column;gap:14px;">
      <a href="tel:+17253406758" class="btn btn-primary">Call: (725) 340-6758</a>
      <a href="https://wa.me/17253406758" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp Us</a>
    </div>
  </div>
  <div><div class="form-card"><h3 style="margin-bottom:6px;">Request Your Free Consultation</h3><p style="color:var(--text-light);font-size:.9rem;margin-bottom:24px;">Fill out the form and we will contact you soon.</p>
    <form id="contact-form">
      <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="nombre" placeholder="Your full name" required/></div><div class="form-group"><label>Phone *</label><input type="tel" name="telefono" placeholder="(702) 000-0000" required/></div></div>
      <div class="form-group"><label>Email</label><input type="email" name="email" placeholder="you@email.com"/></div>
      <div class="form-group"><label>What Do You Need? *</label><select name="servicio" required><option value="">Select...</option><option>Personal Tax Preparation</option><option>Business/LLC Tax Preparation</option><option>LLC Formation</option><option>Monthly Bookkeeping</option><option>Payroll</option><option>IRS Letter</option><option>Other</option></select></div>
      <div class="form-group"><label>Additional Message</label><textarea name="mensaje" placeholder="Tell us briefly about your situation..."></textarea></div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;font-size:1.1rem;padding:16px;">Request Free Consultation</button>
    </form>
  </div></div>
</div></div></section>
</Layout>
