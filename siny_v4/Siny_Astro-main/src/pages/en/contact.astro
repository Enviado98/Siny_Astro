---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Contact – Guzman Tax Accounting Las Vegas" description="Contact us for tax and accounting services in Las Vegas. Bilingual service available." lang="en" langHref="/contacto">
<section class="page-hero"><div class="container"><div class="breadcrumb"><a href="/en/">Home</a> <span>›</span> <span>Contact</span></div><h1>Contact Us</h1><p>Bilingual service available. Call or write to us.</p></div></section>
<section class="section"><div class="container"><div class="contact-grid">
  <div class="contact-info"><p class="eyebrow">We Are Here</p><h2>Talk to Us</h2><p>English and Spanish service available. Do not hesitate to contact us however you prefer.</p>
    <div class="contact-detail"><div class="contact-detail-icon">📍</div><div class="contact-detail-text"><h4>Address</h4><p>4760 S Pecos Rd Suite 103-20<br/>Las Vegas, Nevada 89121</p></div></div>
    <div class="contact-detail"><div class="contact-detail-icon">📞</div><div class="contact-detail-text"><h4>Phone / WhatsApp</h4><p><a href="tel:+17253406758">(725) 340-6758</a></p></div></div>
    <div class="contact-detail"><div class="contact-detail-icon">✉️</div><div class="contact-detail-text"><h4>Email</h4><p><a href="mailto:info@guzmantaxaccounting.com">info@guzmantaxaccounting.com</a></p></div></div>
    <div class="contact-detail"><div class="contact-detail-icon">🕐</div><div class="contact-detail-text"><h4>Hours</h4><p>Sunday – Friday: 9 AM – 7 PM</p></div></div>
  </div>
  <div><div class="form-card"><h3 style="margin-bottom:6px;">Send Us a Message</h3><p style="color:var(--text-light);font-size:.9rem;margin-bottom:24px;">We will respond within 24 hours.</p>
    <form id="contact-form">
      <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="nombre" placeholder="Your full name" required/></div><div class="form-group"><label>Phone</label><input type="tel" name="telefono" placeholder="(702) 000-0000"/></div></div>
      <div class="form-group"><label>Email *</label><input type="email" name="email" placeholder="you@email.com" required/></div>
      <div class="form-group"><label>Service of Interest</label><select name="servicio"><option value="">Select a service...</option><option>Tax Preparation</option><option>Bookkeeping</option><option>Payroll</option><option>LLC Formation</option><option>IRS Letters</option><option>Other</option></select></div>
      <div class="form-group"><label>Message *</label><textarea name="mensaje" placeholder="Tell us how we can help you..." required></textarea></div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Send Message</button>
    </form>
  </div></div>
</div></div></section>
</Layout>
