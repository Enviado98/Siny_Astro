---
export interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;
const isEs = lang === 'es';
---

<footer class="footer">
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <div class="footer-brand">
          <div class="logo-text logo-text--footer"><span class="logo-g">G</span>uzmán</div>
          <p>{isEs
            ? 'Firma contable bilingüe en Las Vegas, Nevada. Servicios de taxes, contabilidad y asesoría financiera para la comunidad latina.'
            : 'Bilingual accounting firm in Las Vegas, Nevada. Tax, accounting and financial advisory services for the Latino community.'
          }</p>
          <div style="display:flex;gap:12px;margin-top:16px;">
            <a href="https://www.facebook.com/guzmantaxaccounting" target="_blank" rel="noopener" style="color:var(--primary);font-size:1.3rem;">
              <span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></span>
            </a>
            <a href="https://wa.me/17253406758" target="_blank" rel="noopener" style="color:var(--primary);font-size:1.3rem;">
              <span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.558 4.14 1.533 5.878L.057 23.492a.5.5 0 0 0 .613.613l5.614-1.476A11.934 11.934 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.65-.507-5.17-1.395l-.37-.217-3.838 1.006 1.022-3.734-.24-.387A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg></span>
            </a>
          </div>
        </div>

        <div class="footer-col">
          <h4>{isEs ? 'Servicios' : 'Services'}</h4>
          <ul>
            <li><a href={isEs ? '/servicios' : '/en/services'}>{isEs ? 'Preparación de Impuestos' : 'Tax Preparation'}</a></li>
            <li><a href={isEs ? '/servicios' : '/en/services'}>Bookkeeping</a></li>
            <li><a href={isEs ? '/servicios' : '/en/services'}>{isEs ? 'Nómina y Payroll' : 'Payroll'}</a></li>
            <li><a href={isEs ? '/servicios' : '/en/services'}>{isEs ? 'Creación de LLC' : 'LLC Formation'}</a></li>
            <li><a href={isEs ? '/servicios' : '/en/services'}>{isEs ? 'Planeación Fiscal' : 'Tax Planning'}</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>{isEs ? 'Empresa' : 'Company'}</h4>
          <ul>
            <li><a href={isEs ? '/nuestro-equipo' : '/en/about'}>{isEs ? 'Quiénes Somos' : 'About Us'}</a></li>
            <li><a href={isEs ? '/blog' : '/en/blog'}>{isEs ? 'Blog Fiscal' : 'Blog'}</a></li>
            <li><a href={isEs ? '/consulta-gratuita' : '/en/free-consultation'}>{isEs ? 'Consulta Gratis' : 'Free Consult'}</a></li>
            <li><a href={isEs ? '/portal-de-clientes' : '/en/client-portal'}>{isEs ? 'Portal Clientes' : 'Client Portal'}</a></li>
            <li><a href={isEs ? '/contacto' : '/en/contact'}>{isEs ? 'Contacto' : 'Contact'}</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>{isEs ? 'Contacto' : 'Contact'}</h4>
          <div class="footer-contact-item">
            <span class="icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-8 12-8 12z"/><circle cx="12" cy="9" r="3"/></svg></span></span>
            <span>4760 S Pecos Rd Suite 103-20<br/>Las Vegas, NV 89121</span>
          </div>
          <div class="footer-contact-item">
            <span class="icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l1.92-1.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span></span>
            <a href="tel:+17253406758">(725) 340-6758</a>
          </div>
          <div class="footer-contact-item">
            <span class="icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2 4 12 13 22 4"/></svg></span></span>
            <a href="mailto:info@guzmantaxaccounting.com">info@guzmantaxaccounting.com</a>
          </div>
          <div class="footer-contact-item">
            <span class="icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span></span>
            <span>{isEs ? 'Dom – Vie: 9 AM – 7 PM' : 'Sun – Fri: 9 AM – 7 PM'}</span>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="container">
    <div class="footer-bottom">
      <span>© 2026 Guzman Tax Accounting & Multi-Services. All Rights Reserved.</span>
      <div class="footer-bottom-links">
        <a href={isEs ? '/terminos-y-condiciones' : '/en/terms'}>{isEs ? 'Términos y Condiciones' : 'Terms'}</a>
        <a href={isEs ? '/politica-de-privacidad' : '/en/privacy-policy'}>{isEs ? 'Política de Privacidad' : 'Privacy Policy'}</a>
        <a href={isEs ? '/aviso-legal' : '/en/legal-notice'}>{isEs ? 'Aviso Legal' : 'Legal Notice'}</a>
      </div>
    </div>
  </div>
</footer>
