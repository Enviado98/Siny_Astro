</section>

<script>
(function () {
  const siny   = document.querySelector('.hero-photo-siny-wrap');
  const jeziel = document.querySelector('.hero-photo-jeziel-wrap');
  const names  = document.querySelectorAll('.hero-team-name');

  if (!siny || !jeziel) return;

  const ENTRY_DELAY = 1400;

  setTimeout(() => {
    const supportsScrollTimeline = CSS.supports('animation-timeline', 'scroll()');

    if (supportsScrollTimeline) {
      siny.style.opacity   = '1';
      jeziel.style.opacity = '1';
      siny.classList.add('scroll-ready');
      jeziel.classList.add('scroll-ready');
      names.forEach(n => n.classList.add('scroll-ready'));
    } else {
      const heroSection = document.querySelector('.hero');
      if (!heroSection) return;

      let ticking = false;

      function update() {
        const rect     = heroSection.getBoundingClientRect();
        const heroH    = heroSection.offsetHeight;
        const progress = Math.min(Math.max(-rect.top / (heroH * 0.45), 0), 1);
        const spread   = progress * 180;
        const fade     = 1 - Math.min(progress * 2.5, 1);

        siny.style.transform   = `translateX(${-spread}px)`;
        jeziel.style.transform = `translateX(${spread}px)`;
        names.forEach(n => { n.style.opacity = fade; });
        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      }, { passive: true });
    }
  }, ENTRY_DELAY);
})();
</script>

<section class="section"><div class="container">
