---
import HomeLayout from '../../layouts/HomeLayout.astro';
import { en } from '../../i18n/en';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    { "@type": ["AccountingService","Organization"], "@id": "https://www.guzmantaxaccounting.com/#organization", "name": "Guzman Tax Accounting & Multi Services", "url": "https://www.guzmantaxaccounting.com", "telephone": "+1-725-340-6758", "openingHours": ["Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday 09:00-17:00"], "address": { "@type": "PostalAddress", "addressLocality": "Las Vegas", "addressRegion": "NV", "addressCountry": "US" } },
    { "@type": "WebSite", "@id": "https://www.guzmantaxaccounting.com/#website", "url": "https://www.guzmantaxaccounting.com", "name": "Guzman Tax Accounting & Multi Services", "inLanguage": "en" },
    { "@type": "WebPage", "@id": "https://www.guzmantaxaccounting.com/en/#webpage", "url": "https://www.guzmantaxaccounting.com/en/", "name": "Tax & Accounting Services Las Vegas | Bilingual CPA Near You", "inLanguage": "en" }
  ]
});
---

<HomeLayout
  t={en}
  lang="en"
  langHref="/"
  title={en.title}
  description={en.description}
  canonical="https://www.guzmantaxaccounting.com/en/"
  hreflangEs="https://guzmantaxaccounting.com/"
  hreflangEn="https://guzmantaxaccounting.com/en/"
  schema={schema}
/>
