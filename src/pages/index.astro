---
import HomeLayout from '../layouts/HomeLayout.astro';
import { es } from '../i18n/es';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    { "@type": ["AccountingService","Organization"], "@id": "https://www.guzmantaxaccounting.com/#organization", "name": "Guzman Tax Accounting & Multi Services", "url": "https://www.guzmantaxaccounting.com", "telephone": "+1-725-340-6758", "openingHours": ["Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday 09:00-17:00"], "address": { "@type": "PostalAddress", "addressLocality": "Las Vegas", "addressRegion": "NV", "addressCountry": "US" } },
    { "@type": "WebSite", "@id": "https://www.guzmantaxaccounting.com/#website", "url": "https://www.guzmantaxaccounting.com", "name": "Guzman Tax Accounting & Multi Services", "inLanguage": "es" },
    { "@type": "WebPage", "@id": "https://www.guzmantaxaccounting.com/#webpage", "url": "https://www.guzmantaxaccounting.com/", "name": "Taxes en Español Las Vegas | Contador Cerca de Ti", "inLanguage": "es" }
  ]
});
---

<HomeLayout
  t={es}
  lang="es"
  langHref="/en/"
  title={es.title}
  description={es.description}
  canonical="https://www.guzmantaxaccounting.com/"
  hreflangEs="https://guzmantaxaccounting.com/"
  hreflangEn="https://guzmantaxaccounting.com/en/"
  schema={schema}
/>
