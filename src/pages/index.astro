---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["AccountingService", "Organization"],
      "@id": "https://www.guzmantaxaccounting.com/#organization",
      "name": "Guzman Tax Accounting & Multi Services",
      "url": "https://www.guzmantaxaccounting.com",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://www.guzmantaxaccounting.com/#logo",
        "url": "https://www.guzmantaxaccounting.com/wp-content/uploads/2025/11/cropped-FINAL-LOGO-2.png",
        "contentUrl": "https://www.guzmantaxaccounting.com/wp-content/uploads/2025/11/cropped-FINAL-LOGO-2.png",
        "caption": "Guzman Tax Accounting & Multi Services",
        "inLanguage": "es",
        "width": "1080",
        "height": "446"
      },
      "openingHours": ["Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday 09:00-17:00"],
      "telephone": "+1-725-340-6758",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Las Vegas",
        "addressRegion": "NV",
        "addressCountry": "US"
      },
      "image": { "@id": "https://www.guzmantaxaccounting.com/#logo" }
    },
    {
      "@type": "WebSite",
      "@id": "https://www.guzmantaxaccounting.com/#website",
      "url": "https://www.guzmantaxaccounting.com",
      "name": "Guzman Tax Accounting & Multi Services",
      "alternateName": "Guzman Tax Accounting",
      "publisher": { "@id": "https://www.guzmantaxaccounting.com/#organization" },
      "inLanguage": "es"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.guzmantaxaccounting.com/#webpage",
      "url": "https://www.guzmantaxaccounting.com/",
      "name": "Taxes en Español Las Vegas | Contador Cerca de Ti",
      "isPartOf": { "@id": "https://www.guzmantaxaccounting.com/#website" },
      "about": { "@id": "https://www.guzmantaxaccounting.com/#organization" },
      "inLanguage": "es"
    }
  ]
});
---

<Layout
  title="Taxes en Español Las Vegas | Contador Cerca de Ti"
  description="Taxes en español Las Vegas | Contador cerca de ti | Preparación de impuestos, bookkeeping y LLC para familias y negocios latinos. Con más de 10 años de experiencia. Atención en español."
  lang="es"
  langHref="/en/"
  hreflangEs="https://guzmantaxaccounting.com/"
  hreflangEn="https://guzmantaxaccounting.com/en/"
  canonical="https://www.guzmantaxaccounting.com/"
  schema={schema}
>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg" style="background-image:url('/assets/2.webp');"></div>
  <div class="container">
    <div class="hero-content fade-in">
      <p class="eyebrow">
        <span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
        Firma Contable Bilingüe · Las Vegas, NV
      </p>
      <h1>Servicios de <span>Taxes y Contabilidad</span> en Las Vegas</h1>
      <p>Atención personalizada en español para personas, familias y negocios. Sin letras pequeñas, sin sorpresas — resultados reales.</p>
      <div class="hero-btns">
        <a href="tel:+17253406758" class="btn btn-primary">
          <span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l1.92-1.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
          Llamar Ahora
        </a>
        <a href="https://wa.me/17253406758" class="btn btn-outline" target="_blank" rel="noopener">
          <span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.558 4.14 1.533 5.878L.057 23.492a.5.5 0 0 0 .613.613l5.614-1.476A11.934 11.934 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.65-.507-5.17-1.395l-.37-.217-3.838 1.006 1.022-3.734-.24-.387A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg></span>
          WhatsApp
        </a>
      </div>
      <div class="hero-badges">
        <div class="hero-badge"><span><strong>239+</strong> Proyectos Completados</span></div>
        <div class="hero-badge"><span><strong>24/7</strong> Soporte en Español</span></div>
        <div class="hero-badge"><span><strong>10+</strong> Años de Experiencia</span></div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Lo que hacemos</p>
      <h2>Nuestra Experiencia en Servicios Contables y Fiscales</h2>
      <p>Soluciones completas para tu situación fiscal y financiera, explicadas en tu idioma.</p>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 3H7a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9z"/><path d="M14 3v6h6"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg></div>
        <h3>Preparación de Impuestos</h3>
        <p>Taxes personales y de negocios: 1040, LLC, S-Corp, C-Corp. Maximizamos tu reembolso legalmente.</p>
        <a href="/taxes" style="color:var(--primary);font-weight:600;font-size:.9rem;margin-top:14px;display:inline-block;">Ver más →</a>
      </div>
      <div class="service-card">
        <div class="service-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="20" x2="20" y2="20"/><line x1="7" y1="20" x2="7" y2="14"/><line x1="12" y1="20" x2="12" y2="9"/><line x1="17" y1="20" x2="17" y2="4"/></svg></div>
        <h3>Bookkeeping en Español</h3>
        <p>Conciliación mensual, registros contables y estados financieros claros para tu negocio.</p>
        <a href="/servicios" style="color:var(--primary);font-weight:600;font-size:.9rem;margin-top:14px;display:inline-block;">Ver más →</a>
      </div>
      <div class="service-card">
        <div class="service-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg></div>
        <h3>Nómina y Payroll</h3>
        <p>Procesamiento de nómina, W-2, 1099, depósito directo y cumplimiento fiscal federal y estatal.</p>
        <a href="/servicios" style="color:var(--primary);font-weight:600;font-size:.9rem;margin-top:14px;display:inline-block;">Ver más →</a>
      </div>
      <div class="service-card">
        <div class="service-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L20.5 7v10L12 22 3.5 17V7z"/></svg></div>
        <h3>Creación de LLC en USA</h3>
        <p>Te ayudamos a formar tu LLC correctamente, incluyendo EIN, operating agreement y cumplimiento estatal.</p>
        <a href="/servicios" style="color:var(--primary);font-weight:600;font-size:.9rem;margin-top:14px;display:inline-block;">Ver más →</a>
      </div>
      <div class="service-card">
        <div class="service-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="13" rx="1"/><path d="M3 7l9 7 9-7"/></svg></div>
        <h3>Cartas del IRS</h3>
        <p>Atención y respuesta a cartas del IRS, auditorías y soporte de cumplimiento fiscal.</p>
        <a href="/servicios" style="color:var(--primary);font-weight:600;font-size:.9rem;margin-top:14px;display:inline-block;">Ver más →</a>
      </div>
      <div class="service-card">
        <div class="service-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="14" rx="1"/><line x1="2" y1="8" x2="22" y2="8"/><line x1="8" y1="22" x2="16" y2="22"/><line x1="12" y1="18" x2="12" y2="22"/></svg></div>
        <h3>Diseño Web y E-Commerce</h3>
        <p>Sitio web gratuito de 1 página al crear una LLC o contratar nuestros servicios. Hosting incluido.</p>
        <a href="/servicios" style="color:var(--primary);font-weight:600;font-size:.9rem;margin-top:14px;display:inline-block;">Ver más →</a>
      </div>
    </div>
    <div class="text-center" style="margin-top:40px;">
      <a href="/servicios" class="btn btn-outline">Ver Todos los Servicios</a>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="number" data-target="239" data-suffix="+">239+</span>
        <span class="label">Proyectos Completados</span>
      </div>
      <div class="stat-item">
        <span class="number">24/7</span>
        <span class="label">Soporte en Español</span>
      </div>
      <div class="stat-item">
        <span class="number" data-target="10" data-suffix="+">10+</span>
        <span class="label">Años de Experiencia</span>
      </div>
      <div class="stat-item">
        <span class="number">100%</span>
        <span class="label">Atención Personalizada</span>
      </div>
    </div>
  </div>
</section>

<!-- MISSION -->
<section class="section bg-gray">
  <div class="container">
    <div class="mission-grid">
      <div class="mission-content">
        <p class="eyebrow">Nuestra Misión</p>
        <h2>En Qué Creemos</h2>
        <p>Nuestra misión es apoyar a personas y negocios brindando soluciones contables personalizadas, asesoría financiera estratégica y un enfoque cercano, <span class="highlight">enfocado en cada cliente.</span></p>
        <p>Creemos en el valor de trabajar cara a cara para construir relaciones de confianza a largo plazo, mientras educamos a nuestros clientes sobre taxes, contabilidad y planeación financiera.</p>
        <div class="mission-points">
          <div class="mission-point">
            <div class="mission-point-icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span></div>
            <div class="mission-point-text"><h4>Claridad Total</h4><p>Sin letras pequeñas, sin sorpresas. Explicamos todo en tu idioma.</p></div>
          </div>
          <div class="mission-point">
            <div class="mission-point-icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span></div>
            <div class="mission-point-text"><h4>Confianza y Honestidad</h4><p>Dos décadas de trayectoria con la comunidad latina en Las Vegas.</p></div>
          </div>
          <div class="mission-point">
            <div class="mission-point-icon"><span class="svg-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span></div>
            <div class="mission-point-text"><h4>Servicio Humano</h4><p>No trabajamos solo con números. Trabajamos con personas.</p></div>
          </div>
        </div>
        <a href="/nuestro-equipo" class="btn btn-primary" style="margin-top:28px;">Conoce al Equipo</a>
      </div>
      <div class="mission-image">
        <img src="/assets/team.webp" alt="Equipo Guzman Tax Accounting" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Precios Transparentes</p>
      <h2>Servicios con Precios Claros y Sin Sorpresas</h2>
      <p>Cotización con expertos en taxes y contabilidad. Sin cargos ocultos.</p>
    </div>
    <div class="pricing-grid">
      <div class="pricing-card">
        <h3>Individual / Familiar</h3>
        <div class="price">Desde $150</div>
        <p class="price-note">Por declaración</p>
        <ul class="pricing-features">
          <li>Forma 1040 Federal + State</li>
          <li>W-2, 1099, intereses</li>
          <li>Créditos fiscales (EITC, CTC)</li>
          <li>Revisión de años anteriores</li>
          <li>Atención en español</li>
        </ul>
        <a href="/consulta-gratuita" class="btn btn-outline" style="width:100%;justify-content:center;">Consulta Gratis</a>
      </div>
      <div class="pricing-card featured">
        <div class="pricing-badge">Más Popular</div>
        <h3>Negocio / LLC</h3>
        <div class="price">Desde $350</div>
        <p class="price-note">Por declaración anual</p>
        <ul class="pricing-features">
          <li>LLC, S-Corp, C-Corp</li>
          <li>Schedule C / Schedule E</li>
          <li>Bookkeeping mensual</li>
          <li>Nómina y Payroll</li>
          <li>Asesoría fiscal estratégica</li>
          <li>Soporte ante el IRS</li>
        </ul>
        <a href="/consulta-gratuita" class="btn btn-white" style="width:100%;justify-content:center;">Consulta Gratis</a>
      </div>
      <div class="pricing-card">
        <h3>CPA Virtual</h3>
        <div class="price">A Medida</div>
        <p class="price-note">Soporte mensual</p>
        <ul class="pricing-features">
          <li>CFO virtual para tu negocio</li>
          <li>Planeación fiscal anual</li>
          <li>Reportes financieros mensuales</li>
          <li>Estrategias de retiro (401k, IRA)</li>
          <li>Atención prioritaria</li>
        </ul>
        <a href="/consulta-gratuita" class="btn btn-outline" style="width:100%;justify-content:center;">Contáctanos</a>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="section testimonials-section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Reseñas</p>
      <h2>Lo que Dicen Nuestros Clientes en Las Vegas</h2>
      <p>Reseñas verificadas de Google de clientes reales.</p>
    </div>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <div class="testimonial-card-top">
          <div class="testimonial-stars">★★★★★</div>
          <svg class="testimonial-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </div>
        <p class="testimonial-text">"They helped me out with an issue with my taxes where I had two W-2s with the same info and it was a mistake from payroll. They fixed the issue and contacted the IRS for me. I didn't have to worry anymore about getting to pay extra taxes. Thanks for the help!"</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">MR</div>
          <div><h4>Mitchell Rhoads</h4><p>Cliente verificado · Google</p></div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-card-top">
          <div class="testimonial-stars">★★★★★</div>
          <svg class="testimonial-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </div>
        <p class="testimonial-text">"Excelente servicio. Me ayudaron con mis taxes de negocio de forma muy profesional. Todo claro, sin sorpresas. 100% recomendados para la comunidad latina en Las Vegas."</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">CA</div>
          <div><h4>Carlos Avirón</h4><p>Cliente verificado · Google</p></div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-card-top">
          <div class="testimonial-stars">★★★★★</div>
          <svg class="testimonial-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </div>
        <p class="testimonial-text">"Muy buena atención, me explicaron todo en español y me ayudaron a maximizar mi reembolso. Definitivamente voy a volver el próximo año."</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">JP</div>
