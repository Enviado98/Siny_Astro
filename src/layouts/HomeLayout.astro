---
import Layout from './Layout.astro';
import type { HomeTranslations } from '../i18n/es';

export interface Props {
  t: HomeTranslations;
  lang: 'es' | 'en';
  langHref: string;
  title: string;
  description: string;
  canonical: string;
  hreflangEs: string;
  hreflangEn: string;
  schema: string;
}

const { t, lang, langHref, title, description, canonical, hreflangEs, hreflangEn, schema } = Astro.props;

// Hero word split
const h1Words: { word: string; accent: boolean }[] = [
  ...t.hero.h1a.trim().split(/\s+/).map((w: string) => ({ word: w, accent: false })),
  ...t.hero.h1span.trim().split(/\s+/).map((w: string) => ({ word: w, accent: true })),
  ...(t.hero.h1b ? t.hero.h1b.trim().split(/\s+/).map((w: string) => ({ word: w, accent: false })) : []),
].filter((w: { word: string; accent: boolean }) => w.word);

// SVG icons reused across sections
const iconPhone = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l1.92-1.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`;
const iconWA = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.558 4.14 1.533 5.878L.057 23.492a.5.5 0 0 0 .613.613l5.614-1.476A11.934 11.934 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.65-.507-5.17-1.395l-.37-.217-3.838 1.006 1.022-3.734-.24-.387A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>`;
const iconStar = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
const iconCheck = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;
const iconShield = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`;
const iconHeart = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`;
const missionIcons = [iconCheck, iconShield, iconHeart];

const serviceColors = [
  '#39FF14', // neon green
  '#FF6B00', // neon orange
  '#FF1E8C', // hot pink
  '#CCFF00', // lime yellow
  '#3B9EFF', // electric blue
  '#C8B8FF', // soft lavender
];

const serviceIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 3H7a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9z"/><path d="M14 3v6h6"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="20" x2="20" y2="20"/><line x1="7" y1="20" x2="7" y2="14"/><line x1="12" y1="20" x2="12" y2="9"/><line x1="17" y1="20" x2="17" y2="4"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L20.5 7v10L12 22 3.5 17V7z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="13" rx="1"/><path d="M3 7l9 7 9-7"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="14" rx="1"/><line x1="2" y1="8" x2="22" y2="8"/><line x1="8" y1="22" x2="16" y2="22"/><line x1="12" y1="18" x2="12" y2="22"/></svg>`,
];

const googleIcon = `<svg class="testimonial-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>`;
---

<Layout
  title={title}
  description={description}
  lang={lang}
  langHref={langHref}
  hreflangEs={hreflangEs}
  hreflangEn={hreflangEn}
  canonical={canonical}
  schema={schema}
>

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-bg" style="background-image:url('/assets/2.webp');"></div>
  <div class="container">
    <div class="hero-display">
      <div class="hero-team">
        <div class="hero-team-member hero-photo-siny-wrap">
          <img class="hero-team-photo hero-photo-siny" src="/assets/siny-hero.webp" alt="Siny Guzmán" />
          <span class="hero-team-name">Siny Guzmán</span>
        </div>
        <div class="hero-team-member hero-photo-jeziel-wrap">
          <img class="hero-team-photo hero-photo-jeziel" src="/assets/jeziel-hero.webp" alt="Jeziel Guzmán" />
          <span class="hero-team-name">Jeziel Guzmán</span>
        </div>
      </div>
    </div>
    <div class="hero-content hero-content-animated">
      <p class="eyebrow hero-eyebrow-anim">
        <span class="svg-icon" set:html={iconStar} />
        {t.hero.eyebrow}
      </p>
      <h1 class="hero-h1-split">
        {h1Words.map((item, i) => (
          <span class={`hero-word${item.accent ? ' hero-word-accent' : ''}`} style={`--i:${i}`}>{item.word}</span>
        ))}
      </h1>
      <p>{t.hero.p}</p>
      <div class="hero-btns">
        <a href="tel:+17253406758" class="btn btn-primary">
          <span class="svg-icon" set:html={iconPhone} />{t.hero.cta1}
        </a>
        <a href="https://wa.me/17253406758" class="btn btn-outline" target="_blank" rel="noopener">
          <span class="svg-icon" set:html={iconWA} />{t.hero.cta2}
        </a>
      </div>
      <div class="hero-badges">
        <div class="hero-badge"><span><strong>{t.hero.badge1.split(' ')[0]}</strong> {t.hero.badge1.split(' ').slice(1).join(' ')}</span></div>
        <div class="hero-badge"><span><strong>{t.hero.badge2.split(' ')[0]}</strong> {t.hero.badge2.split(' ').slice(1).join(' ')}</span></div>
        <div class="hero-badge"><span><strong>{t.hero.badge3.split(' ')[0]}</strong> {t.hero.badge3.split(' ').slice(1).join(' ')}</span></div>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const siny   = document.querySelector('.hero-photo-siny-wrap');
  const jeziel = document.querySelector('.hero-photo-jeziel-wrap');
  const names  = document.querySelectorAll('.hero-team-name');
  if (!siny || !jeziel) return;
  setTimeout(() => {
    if (CSS.supports('animation-timeline', 'scroll()')) {
      siny.style.opacity = jeziel.style.opacity = '1';
      siny.classList.add('scroll-ready');
      jeziel.classList.add('scroll-ready');
      names.forEach(n => n.classList.add('scroll-ready'));
    } else {
      const heroSection = document.querySelector('.hero');
      if (!heroSection) return;
      let ticking = false;
      function update() {
        const rect = heroSection.getBoundingClientRect();
        const progress = Math.min(Math.max(-rect.top / (heroSection.offsetHeight * 0.45), 0), 1);
        const spread = progress * 180;
        const fadeOut = 1 - Math.min(progress * 2.5, 1);
        siny.style.transform   = `translateX(${-spread}px)`;
        jeziel.style.transform = `translateX(${spread}px)`;
        siny.style.opacity     = String(fadeOut);
        jeziel.style.opacity   = String(fadeOut);
        names.forEach(n => { n.style.opacity = String(fadeOut); });
        ticking = false;
      }
      window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(update); ticking = true; } }, { passive: true });
    }
  }, 1400);
})();
</script>



<!-- ── SERVICES ── -->
<section class="services-carousel-section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">{t.services.eyebrow}</p>
      <h2>{t.services.h2}</h2>
      <p>{t.services.p}</p>
    </div>
  </div>
  <div class="services-carousel-track-wrap">
    <div class="services-carousel">
      {t.services.items.map((svc, i) => (
        <a href={svc.href} class="service-card-color" style={`--card-color:${serviceColors[i]}`}>
          <div class="scc-body">
            <h3>{svc.title}</h3>
            <p>{svc.p}</p>
          </div>
          <div class="scc-footer">
            <div class="scc-icon" set:html={serviceIcons[i]} />
            <span class="scc-link">{t.services.learnMore} →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
  <div class="container">
    <div class="text-center" style="margin-top:40px;">
      <a href={t.services.ctaHref} class="btn btn-outline">{t.services.cta}</a>
    </div>
  </div>
</section>

<script>
(function initServicesDrag() {
  const carousel = document.querySelector('.services-carousel');
  if (!carousel) return;
  let isDown = false, startX, scrollLeft;
  carousel.addEventListener('mousedown', (e) => {
    isDown = true;
    carousel.classList.add('is-dragging');
    startX = e.pageX - carousel.offsetLeft;
    scrollLeft = carousel.scrollLeft;
  });
  carousel.addEventListener('mouseleave', () => { isDown = false; carousel.classList.remove('is-dragging'); });
  carousel.addEventListener('mouseup', () => { isDown = false; carousel.classList.remove('is-dragging'); });
  carousel.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - carousel.offsetLeft;
    carousel.scrollLeft = scrollLeft - (x - startX) * 1.2;
  });
})();

(function initTestimonialsDrag() {
  const carousel = document.querySelector('.testimonials-grid');
  if (!carousel) return;
  let isDown = false, startX, scrollLeft;
  carousel.addEventListener('mousedown', (e) => {
    isDown = true;
    carousel.classList.add('is-dragging');
    startX = e.pageX - carousel.offsetLeft;
    scrollLeft = carousel.scrollLeft;
  });
  carousel.addEventListener('mouseleave', () => { isDown = false; carousel.classList.remove('is-dragging'); });
  carousel.addEventListener('mouseup', () => { isDown = false; carousel.classList.remove('is-dragging'); });
  carousel.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - carousel.offsetLeft;
    carousel.scrollLeft = scrollLeft - (x - startX) * 1.2;
  });
})();
</script>

<!-- ── STATS ── -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      {t.stats.map(s => (
        <div class="stat-item">
          <span class="number" data-target={s.target} data-suffix={s.suffix}>{s.number}</span>
          <span class="label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── MISSION ── -->
<section class="section bg-gray">
  <div class="container">
    <div class="mission-grid">
      <div class="mission-content">
        <p class="eyebrow">{t.mission.eyebrow}</p>
        <h2>{t.mission.h2}</h2>
        <p>{t.mission.p1} <span class="highlight">{t.mission.p1highlight}</span></p>
        <p>{t.mission.p2}</p>
        <div class="mission-points">
          {t.mission.points.map((point, i) => (
            <div class="mission-point">
              <div class="mission-point-icon"><span class="svg-icon" set:html={missionIcons[i]} /></div>
              <div class="mission-point-text"><h4>{point.title}</h4><p>{point.p}</p></div>
            </div>
          ))}
        </div>
        <a href={t.mission.ctaHref} class="btn btn-primary" style="margin-top:28px;">{t.mission.cta}</a>
      </div>
      <div class="mission-image">
        <img src="/assets/team.webp" alt={t.mission.imgAlt} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- ── PRICING ── -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">{t.pricing.eyebrow}</p>
      <h2>{t.pricing.h2}</h2>
      <p>{t.pricing.p}</p>
    </div>
    <div class="pricing-grid">
      {t.pricing.plans.map(plan => (
        <div class={`pricing-card${plan.featured ? ' featured' : ''}`}>
          {plan.featured && <div class="pricing-badge">{t.pricing.badge}</div>}
          <h3>{plan.title}</h3>
          <div class="price">{plan.price}</div>
          <p class="price-note">{plan.note}</p>
          <ul class="pricing-features">
            {plan.features.map(f => <li>{f}</li>)}
          </ul>
          <a href={plan.ctaHref} class={`btn ${plan.featured ? 'btn-white' : 'btn-outline'}`} style="width:100%;justify-content:center;">{plan.cta}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ── -->
<section class="section testimonials-section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">{t.testimonials.eyebrow}</p>
      <h2>{t.testimonials.h2}</h2>
      <p>{t.testimonials.p}</p>
    </div>
  </div>
  <div class="services-carousel-track-wrap">
    <div class="testimonials-grid">
      {t.testimonials.items.map(item => (
        <div class="testimonial-card">
          <div class="testimonial-card-top">
            <div class="testimonial-stars">★★★★★</div>
            <Fragment set:html={googleIcon} />
          </div>
          <p class="testimonial-text">"{item.text}"</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{item.initials}</div>
            <div><h4>{item.name}</h4><p>{t.testimonials.verifiedLabel}</p></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── BLOG ── -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">{t.blog.eyebrow}</p>
      <h2>{t.blog.h2}</h2>
    </div>
    <div class="blog-grid">
      {t.blog.posts.map(post => (
        <div class="blog-card">
          <div class="blog-card-img"><img src={post.img} alt={post.imgAlt} loading="lazy" /></div>
          <div class="blog-card-body">
            <span class="blog-tag">{post.tag}</span>
            <h3><a href={post.href}>{post.title}</a></h3>
            <p>{post.p}</p>
            <div class="blog-meta"><span>{post.year}</span><span>{post.min} min</span></div>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center" style="margin-top:40px;">
      <a href={t.blog.ctaHref} class="btn btn-outline">{t.blog.cta}</a>
    </div>
  </div>
</section>

<!-- ── CLIENTS ── -->
<section class="clients-section">
  <div class="container">
    <p class="eyebrow text-center" style="margin-bottom:30px;">{t.clients.eyebrow}</p>
    <div class="clients-grid">
      <img src="/assets/client-av1.webp"     alt="AV Logo"         class="client-logo" loading="lazy" />
      <img src="/assets/client-beyou.webp"   alt="BeYou Logo"      class="client-logo" loading="lazy" />
      <img src="/assets/client-trading.webp" alt="Trading Labels"  class="client-logo" loading="lazy" />
      <img src="/assets/client-cafe.webp"    alt="Cafe Logo"       class="client-logo" loading="lazy" />
    </div>
  </div>
</section>

<!-- ── CTA ── -->
<section class="cta-section">
  <div class="container">
    <p class="eyebrow text-center" style="color:var(--primary);">{t.cta.eyebrow}</p>
    <h2>{t.cta.h2}</h2>
    <p>{t.cta.p}</p>
    <div class="btn-group">
      <a href={t.cta.btn1Href} class="btn btn-primary">{t.cta.btn1}</a>
      <a href="tel:+17253406758" class="btn btn-white">{t.cta.btn2}</a>
    </div>
  </div>
</section>

</Layout>
