---
export interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;
const isEs = lang === 'es';
---

<aside>
  <div class="sidebar-card">
    <h3>{isEs ? 'Consulta Gratuita' : 'Free Consultation'}</h3>
    <p style="font-size:.9rem;color:var(--text-light);margin-bottom:16px;">
      {isEs ? '¿Tienes preguntas sobre tus taxes o negocio? Te ayudamos gratis.' : 'Questions about your taxes or business? We can help for free.'}
    </p>
    <a href={isEs ? '/consulta-gratuita' : '/en/free-consultation'} class="btn btn-primary" style="width:100%;justify-content:center;">
      {isEs ? 'Agendar Ahora' : 'Book Now'}
    </a>
    <a href="tel:+17253406758" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:10px;">(725) 340-6758</a>
  </div>

  <div class="sidebar-card">
    <h3>{isEs ? 'Artículos Recientes' : 'Recent Articles'}</h3>
    <div class="sidebar-post">
      <img src="/assets/taxes-banner.png" alt="" loading="lazy" />
      <div>
        <h4><a href={isEs ? '/preparacion-impuestos-2026' : '/en/tax-preparation-2026'}>{isEs ? 'Impuestos 2026 para la Comunidad Latina' : 'Tax Preparation 2026'}</a></h4>
        <p>2025</p>
      </div>
    </div>
    <div class="sidebar-post">
      <img src="/assets/child-tax-credit-2024-amount.png" alt="" loading="lazy" />
      <div>
        <h4><a href={isEs ? '/child-tax-credit-2024' : '/en/child-tax-credit-2024'}>Child Tax Credit 2024</a></h4>
        <p>2024</p>
      </div>
    </div>
    <div class="sidebar-post">
      <img src="/assets/img-19-1.jpg" alt="" loading="lazy" />
      <div>
        <h4><a href={isEs ? '/irs-immigrants' : '/en/irs-immigrants'}>{isEs ? 'IRS y los Inmigrantes' : 'IRS & Immigrants'}</a></h4>
        <p>2025</p>
      </div>
    </div>
  </div>

  <div class="sidebar-card">
    <h3>{isEs ? 'Nuestros Servicios' : 'Our Services'}</h3>
    <ul style="display:flex;flex-direction:column;gap:8px;font-size:.9rem;">
      <li><a href={isEs ? '/taxes' : '/en/taxes'} style="color:var(--primary);">→ {isEs ? 'Preparación de Taxes' : 'Tax Preparation'}</a></li>
      <li><a href={isEs ? '/servicios' : '/en/services'} style="color:var(--primary);">→ Bookkeeping</a></li>
      <li><a href={isEs ? '/servicios' : '/en/services'} style="color:var(--primary);">→ {isEs ? 'Creación de LLC' : 'LLC Formation'}</a></li>
      <li><a href={isEs ? '/servicios' : '/en/services'} style="color:var(--primary);">→ {isEs ? 'Nómina y Payroll' : 'Payroll'}</a></li>
    </ul>
  </div>
</aside>
